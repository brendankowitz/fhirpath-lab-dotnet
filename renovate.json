{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Group all Ignixa packages together",
      "matchPackagePrefixes": ["Ignixa."],
      "groupName": "ignixa packages"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Group xUnit packages together",
      "matchPackagePrefixes": ["xunit"],
      "groupName": "xunit packages"
    },
    {
      "description": "Group test tooling packages",
      "matchPackageNames": [
        "coverlet.collector",
        "Microsoft.NET.Test.Sdk"
      ],
      "groupName": "test tooling"
    }
  ]
}
